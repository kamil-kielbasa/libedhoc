@PACKAGE_INIT@

# Re-resolve public dependencies before importing the targets.
# backend_cbor links zcbor PUBLIC, so the imported target must be available.
include(CMakeFindDependencyMacro)
find_dependency(zcbor CONFIG)

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-targets.cmake")
check_required_components("@PROJECT_NAME@")

# Export the package location for consumers that locate libedhoc by path.
set(WORKENV_MODULE_LIBEDHOC ${CMAKE_CURRENT_LIST_DIR} CACHE PATH "libedhoc path" INTERNAL)
list(APPEND CMAKE_MODULE_PATH ${CMAKE_CURRENT_LIST_DIR})
