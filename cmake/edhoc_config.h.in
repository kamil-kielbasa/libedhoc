/**
 * \file    edhoc_config.h
 * \brief   Build-time configuration of libedhoc (GENERATED, do not edit).
 *
 * Generated by CMake from cmake/edhoc_config.h.in and installed next to the
 * public headers, so a consumer compiling against an installed libedhoc gets
 * EXACTLY the values the library was built with (no silent ABI mismatch) and
 * needs no special -D flags — it also works for non-CMake build systems.
 *
 * Every value is guarded with #ifndef: on Zephyr the same macros arrive
 * earlier via Kconfig (autoconf.h, -imacros), and Kconfig must win.
 */

/* Header guard ------------------------------------------------------------ */
#ifndef EDHOC_CONFIG_H
#define EDHOC_CONFIG_H

#ifndef CONFIG_LIBEDHOC_ENABLE
#define CONFIG_LIBEDHOC_ENABLE @CONFIG_LIBEDHOC_ENABLE@
#endif

#ifndef CONFIG_LIBEDHOC_KEY_ID_LEN
#define CONFIG_LIBEDHOC_KEY_ID_LEN @CONFIG_LIBEDHOC_KEY_ID_LEN@
#endif

#ifndef CONFIG_LIBEDHOC_MAX_NR_OF_CIPHER_SUITES
#define CONFIG_LIBEDHOC_MAX_NR_OF_CIPHER_SUITES @CONFIG_LIBEDHOC_MAX_NR_OF_CIPHER_SUITES@
#endif

#ifndef CONFIG_LIBEDHOC_MAX_LEN_OF_CONN_ID
#define CONFIG_LIBEDHOC_MAX_LEN_OF_CONN_ID @CONFIG_LIBEDHOC_MAX_LEN_OF_CONN_ID@
#endif

#ifndef CONFIG_LIBEDHOC_MAX_LEN_OF_ECC_KEY
#define CONFIG_LIBEDHOC_MAX_LEN_OF_ECC_KEY @CONFIG_LIBEDHOC_MAX_LEN_OF_ECC_KEY@
#endif

#ifndef CONFIG_LIBEDHOC_MAX_LEN_OF_MAC
#define CONFIG_LIBEDHOC_MAX_LEN_OF_MAC @CONFIG_LIBEDHOC_MAX_LEN_OF_MAC@
#endif

#ifndef CONFIG_LIBEDHOC_MAX_NR_OF_EAD_TOKENS
#define CONFIG_LIBEDHOC_MAX_NR_OF_EAD_TOKENS @CONFIG_LIBEDHOC_MAX_NR_OF_EAD_TOKENS@
#endif

#ifndef CONFIG_LIBEDHOC_MAX_LEN_OF_CRED_KEY_ID
#define CONFIG_LIBEDHOC_MAX_LEN_OF_CRED_KEY_ID @CONFIG_LIBEDHOC_MAX_LEN_OF_CRED_KEY_ID@
#endif

#ifndef CONFIG_LIBEDHOC_MAX_LEN_OF_HASH_ALG
#define CONFIG_LIBEDHOC_MAX_LEN_OF_HASH_ALG @CONFIG_LIBEDHOC_MAX_LEN_OF_HASH_ALG@
#endif

#ifndef CONFIG_LIBEDHOC_MAX_NR_OF_CERTS_IN_X509_CHAIN
#define CONFIG_LIBEDHOC_MAX_NR_OF_CERTS_IN_X509_CHAIN @CONFIG_LIBEDHOC_MAX_NR_OF_CERTS_IN_X509_CHAIN@
#endif

#ifndef CONFIG_LIBEDHOC_LOG_LEVEL
#define CONFIG_LIBEDHOC_LOG_LEVEL @CONFIG_LIBEDHOC_LOG_LEVEL@
#endif

#ifndef CONFIG_LIBEDHOC_MEM_BACKEND
#define CONFIG_LIBEDHOC_MEM_BACKEND @CONFIG_LIBEDHOC_MEM_BACKEND@
#endif

#endif /* EDHOC_CONFIG_H */
